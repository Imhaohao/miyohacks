# OpenAI — also required on the Convex deployment (see note below)
OPENAI_API_KEY=

# Convex (populated by `npx convex dev`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ── Convex backend env (required for auctions) ─────────────────────────────
# Specialist bidding/execution runs in Convex actions, NOT inside Next.js.
# Values in .env.local are only seen by Next (MCP route, pages). For Convex,
# set the same keys on your dev deployment, e.g.:
#   npx convex env set OPENAI_API_KEY 'sk-...'
# Or: Dashboard → your deployment → Settings → Environment Variables.
# Optional: `npx convex env set --from-file .env.convex` with a local file.

# Public host used by the MCP endpoint to return web_view_url back to callers
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk OAuth auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Set this on the Convex deployment too.
CLERK_FRONTEND_API_URL=https://your-clerk-frontend-api.clerk.accounts.dev

# Stripe payments
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx
# Optional shared secret used by Next.js payment routes when calling Convex
PAYMENT_SERVER_SECRET=

# Local-only escape hatch for old unauthenticated MCP demos.
ALLOW_LEGACY_AGENT_IDS=false

# Admin dashboard
ADMIN_DASHBOARD_SECRET=change-me-for-local-admin
ADMIN_SESSION_TTL_HOURS=12

# Optional sponsor integrations (mocked if absent)
REACHER_API_KEY=
NIA_API_KEY=
HYPERSPELL_API_KEY=hs-0-xxxxxxxxxxxxxxxxxxxxxx
TENSORLAKE_API_KEY=
DEVIN_API_KEY=
V0_API_KEY=

# Real Codex execution runner.
# Convex actions cannot edit your laptop checkout directly unless they can
# reach a runner. For local demos, run Next.js on a reachable URL and set:
#   CODEX_RUNNER_URL=http://localhost:3000/api/codex/run
#   CODEX_RUNNER_SECRET=change-me
#   CODEX_WORKSPACE_DIR=/absolute/path/to/the/repo/codex-may-edit
# Set CODEX_RUNNER_URL + CODEX_RUNNER_SECRET on Convex too; keep
# CODEX_WORKSPACE_DIR on the runner host.
CODEX_RUNNER_URL=
CODEX_RUNNER_SECRET=
CODEX_WORKSPACE_DIR=
CODEX_EXEC_PATH=codex
CODEX_EXEC_MODEL=
CODEX_EXEC_TIMEOUT_MS=165000
