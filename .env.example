# OpenAI — also required on the Convex deployment (see note below)
OPENAI_API_KEY=

# Convex (populated by `npx convex dev`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ── Convex backend env (required for auctions) ─────────────────────────────
# Specialist bidding/execution runs in Convex actions, NOT inside Next.js.
# Values in .env.local are only seen by Next (MCP route, pages). For Convex,
# set the same keys on your dev deployment, e.g.:
#   npx convex env set OPENAI_API_KEY 'sk-...'
# Or: Dashboard → your deployment → Settings → Environment Variables.
# Optional: `npx convex env set --from-file .env.convex` with a local file.

# Public host used by the MCP endpoint to return web_view_url back to callers
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk OAuth auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Set this on the Convex deployment too.
CLERK_FRONTEND_API_URL=https://your-clerk-frontend-api.clerk.accounts.dev

# Stripe payments
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx
# Required shared secret used by Next.js server routes when calling Convex.
# Set the same value in local .env, Vercel, and the Convex deployment.
PAYMENT_SERVER_SECRET=replace-with-a-long-random-secret

# Local-only escape hatch for old unauthenticated MCP demos.
ALLOW_LEGACY_AGENT_IDS=false

# Admin dashboard
ADMIN_DASHBOARD_SECRET=change-me-for-local-admin
ADMIN_SESSION_TTL_HOURS=12

# Optional sponsor integrations.
# Real integrations bid only when their API key/endpoint is configured; absent
# sponsor endpoints decline instead of using placeholder execution.
REACHER_API_KEY=
NIA_API_KEY=
HYPERSPELL_API_KEY=hs-0-xxxxxxxxxxxxxxxxxxxxxx
TENSORLAKE_API_KEY=
TENSORLAKE_A2A_ENDPOINT=
TENSORLAKE_A2A_AGENT_CARD_URL=
DEVIN_API_KEY=
DEVIN_A2A_ENDPOINT=
DEVIN_A2A_AGENT_CARD_URL=
V0_API_KEY=
INSFORGE_API_KEY=
INSFORGE_A2A_ENDPOINT=
INSFORGE_A2A_AGENT_CARD_URL=
ASIDE_API_KEY=
ASIDE_A2A_ENDPOINT=
ASIDE_A2A_AGENT_CARD_URL=
CONVEX_AGENT_API_KEY=
CONVEX_A2A_ENDPOINT=
CONVEX_A2A_AGENT_CARD_URL=

# Codex GitHub PR execution.
# Required for codex-writer to bid. PAT may be classic `repo` scope or a
# fine-grained token with contents:write + pull_requests:write on target repos.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY above is also required by codex-writer.
CODEX_DEFAULT_BASE_BRANCH=main
CODEX_PR_LABEL=arbor-codex
CODEX_OPENAI_MODEL=gpt-5.5
CODEX_MAX_FILES_PER_PR=20
CODEX_DEFAULT_TARGET_REPO=
# Future GitHub App support; not required for v1.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# Legacy local/remote Codex CLI runner kept for one-commit rollback only.
CODEX_RUNNER_URL=
CODEX_RUNNER_SECRET=
CODEX_WORKSPACE_DIR=
CODEX_EXEC_PATH=codex
CODEX_EXEC_MODEL=
CODEX_EXEC_TIMEOUT_MS=165000
