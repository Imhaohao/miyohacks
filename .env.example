# OpenAI — also required on the Convex deployment (see note below)
OPENAI_API_KEY=

# Convex (populated by `npx convex dev`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ── Convex backend env (required for auctions) ─────────────────────────────
# Specialist bidding/execution runs in Convex actions, NOT inside Next.js.
# Values in .env.local are only seen by Next (MCP route, pages). For Convex,
# set the same keys on your dev deployment, e.g.:
#   npx convex env set OPENAI_API_KEY 'sk-...'
# Or: Dashboard → your deployment → Settings → Environment Variables.
# Optional: `npx convex env set --from-file .env.convex` with a local file.

# Public host used by the MCP endpoint to return web_view_url back to callers
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional sponsor integrations (mocked if absent)
REACHER_API_KEY=
NIA_API_KEY=
HYPERSPELL_API_KEY=hs-0-xxxxxxxxxxxxxxxxxxxxxx
HYPERSPELL_USER_ID=
TENSORLAKE_API_KEY=
DEVIN_API_KEY=
# Required for Devin MCP when DEVIN_API_KEY is account-scoped instead of org-scoped.
DEVIN_ORG_ID=
V0_API_KEY=
# InsForge backend (mcp-forwarding over https://mcp.insforge.dev/mcp).
# BOTH are required — the hosted MCP uses project-scoped "legacy" auth:
#   X-Api-Key + X-Base-URL. Without both, insforge-backend declines and drops
#   to the demo lane. Grab the key + your project's base URL from the InsForge
#   dashboard (these are not copy-pasteable OAuth tokens).
INSFORGE_API_KEY=
INSFORGE_API_BASE_URL=

# External A2A endpoints — specialists are disabled when these are absent
TENSORLAKE_A2A_ENDPOINT=
TENSORLAKE_A2A_AGENT_CARD_URL=
DEVIN_A2A_ENDPOINT=
DEVIN_A2A_AGENT_CARD_URL=
CONVEX_A2A_ENDPOINT=
CONVEX_A2A_AGENT_CARD_URL=
