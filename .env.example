# OpenAI — also required on the Convex deployment (see note below)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
# Optional OpenAI-compatible base URL for local coding tools or alternate gateways.
# Example for Azure OpenAI v1-compatible tools:
# OPENAI_BASE_URL=https://<azure-openai-resource>.openai.azure.com/openai/v1
OPENAI_BASE_URL=
# Use `api-key` for Azure-style endpoints when driving them through OPENAI_BASE_URL.
OPENAI_API_KEY_HEADER=authorization
OPENAI_REASONING_EFFORT=none

# ── Switchable model runtime ───────────────────────────────────────────────
# openai       = use OPENAI_API_KEY / OPENAI_MODEL
# azure-openai = use Azure OpenAI / Azure AI Foundry OpenAI deployments
# foundry      = use Microsoft Foundry Models chat-completions deployments
# disabled     = fail fast; Convex fallbacks stop remote model spend
ARBOR_MODEL_PROVIDER=openai
ARBOR_AZURE_ENABLED=false
# When true, direct OpenAI fallback is blocked. Use this in Azure-credit mode.
ARBOR_REQUIRE_AZURE=false
# Immediate spend kill switch checked before every model call.
ARBOR_MODEL_SPEND_DISABLED=false
# Optional output-token cap for all model calls, with per-purpose overrides.
ARBOR_MAX_OUTPUT_TOKENS=
ARBOR_AGENT_MAX_OUTPUT_TOKENS=
ARBOR_JUDGE_MAX_OUTPUT_TOKENS=
ARBOR_SUGGESTER_MAX_OUTPUT_TOKENS=
ARBOR_MODEL=
ARBOR_AGENT_MODEL=
ARBOR_JUDGE_MODEL=
ARBOR_SUGGESTER_MODEL=
ARBOR_INTAKE_MODEL=
ARBOR_PLANNER_MODEL=
ARBOR_DISCOVERY_MODEL=
ARBOR_DEMO_MODEL=

# Azure OpenAI / Foundry OpenAI v1. Prefer Responses API for GPT-5 deployments.
# Set these in both Next/Vercel and Convex when Arbor model calls run in Convex.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_MODE=responses
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_AGENT_DEPLOYMENT=gpt5-agent
AZURE_OPENAI_JUDGE_DEPLOYMENT=arbor-judge-base
AZURE_OPENAI_SUGGESTER_DEPLOYMENT=arbor-suggester-base
AZURE_OPENAI_AGENT_BASE_MODEL=gpt-5
AZURE_OPENAI_AGENT_MODEL_VERSION=2025-08-07
AZURE_OPENAI_AGENT_SKU=GlobalStandard
AZURE_OPENAI_JUDGE_BASE_MODEL=gpt-4.1-mini
AZURE_OPENAI_JUDGE_BASE_MODEL_VERSION=2025-04-14
AZURE_OPENAI_JUDGE_SKU=GlobalStandard
AZURE_OPENAI_SUGGESTER_BASE_MODEL=gpt-4.1-mini
AZURE_OPENAI_SUGGESTER_BASE_MODEL_VERSION=2025-04-14
AZURE_OPENAI_SUGGESTER_SKU=GlobalStandard
AZURE_OPENAI_JUDGE_FINE_TUNED_DEPLOYMENT=arbor-judge
AZURE_OPENAI_SUGGESTER_FINE_TUNED_DEPLOYMENT=arbor-suggester
AZURE_OPENAI_INTAKE_DEPLOYMENT=
AZURE_OPENAI_PLANNER_DEPLOYMENT=
AZURE_OPENAI_DISCOVERY_DEPLOYMENT=
AZURE_OPENAI_DEMO_DEPLOYMENT=
# Deployment/admin metadata used by `npm run azure:ft -- deploy` and shutoff.
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=northcentralus
AZURE_NAME_PREFIX=arbor
AZURE_BUDGET_EMAIL=
AZURE_BUDGET_NAME=arbor-azure-credits-guardrail
AZURE_CREDITS_TOTAL=10000
AZURE_MONTHLY_BUDGET=9500
AZURE_BUDGET_START=2026-06-01T00:00:00Z
AZURE_BUDGET_END=2027-06-01T00:00:00Z
AZURE_OPENAI_RESOURCE_NAME=
AZURE_CONTAINER_APP_NAME=
AZURE_WEBAPP_NAME=
AZURE_MANAGEMENT_TOKEN=

# Microsoft Foundry Models non-OpenAI deployments, e.g. DeepSeek/Grok/etc.
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_API_KEY=
AZURE_INFERENCE_CREDENTIAL=
AZURE_FOUNDRY_API_VERSION=2024-10-21
AZURE_FOUNDRY_DEPLOYMENT=
AZURE_FOUNDRY_AGENT_DEPLOYMENT=
AZURE_FOUNDRY_JUDGE_DEPLOYMENT=
AZURE_FOUNDRY_SUGGESTER_DEPLOYMENT=

# Convex (populated by `npx convex dev`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ── Convex backend env (required for auctions) ─────────────────────────────
# Specialist bidding/execution runs in Convex actions, NOT inside Next.js.
# Values in .env.local are only seen by Next (MCP route, pages). For Convex,
# set the same keys on your dev deployment, e.g.:
#   npx convex env set OPENAI_API_KEY 'sk-...'
#   npx convex env set ARBOR_MODEL_PROVIDER azure-openai
#   npx convex env set AZURE_OPENAI_ENDPOINT 'https://<resource>.openai.azure.com'
#   npx convex env set AZURE_OPENAI_API_KEY '...'
#   npx convex env set AZURE_OPENAI_AGENT_DEPLOYMENT gpt5-agent
#   npx convex env set AZURE_OPENAI_JUDGE_DEPLOYMENT arbor-judge
#   npx convex env set AZURE_OPENAI_SUGGESTER_DEPLOYMENT arbor-suggester
# Emergency all-model-spend shutoff:
#   npx convex env set ARBOR_MODEL_PROVIDER disabled
# Or: Dashboard → your deployment → Settings → Environment Variables.
# Optional: `npx convex env set --from-file .env.convex` with a local file.

# Public host used by the MCP endpoint to return web_view_url back to callers
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Real payments (disabled unless ARBOR_PAYMENTS_MODE=stripe_checkout) ────
# Keep unset for simulated Convex escrow. When enabled, set these in both
# Next/Vercel and Convex where noted:
#   npx convex env set ARBOR_PAYMENTS_MODE stripe_checkout
#   npx convex env set STRIPE_SECRET_KEY sk_test_...
#   npx convex env set STRIPE_CURRENCY usd
ARBOR_PAYMENTS_MODE=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_CONNECT_COUNTRY=US
STRIPE_CONNECT_BUSINESS_URL=http://localhost:3000
STRIPE_CONNECT_PRODUCT_DESCRIPTION=Arbor agent marketplace services
ARBOR_PLATFORM_FEE_BPS=1000
# Optional but recommended in production. Set the same value in Next and Convex
# so verified Next Stripe routes can update Convex payment state.
ARBOR_STRIPE_CONVEX_BRIDGE_SECRET=

# Optional sponsor integrations (mocked if absent)
REACHER_API_KEY=
NIA_API_KEY=
HYPERSPELL_API_KEY=hs-0-xxxxxxxxxxxxxxxxxxxxxx
HYPERSPELL_USER_ID=
TENSORLAKE_API_KEY=
DEVIN_API_KEY=
# Required for Devin MCP when DEVIN_API_KEY is account-scoped instead of org-scoped.
DEVIN_ORG_ID=
V0_API_KEY=
# InsForge backend (mcp-forwarding over https://mcp.insforge.dev/mcp).
# BOTH are required — the hosted MCP uses project-scoped "legacy" auth:
#   X-Api-Key + X-Base-URL. Without both, insforge-backend declines and drops
#   to the demo lane. Grab the key + your project's base URL from the InsForge
#   dashboard (these are not copy-pasteable OAuth tokens).
INSFORGE_API_KEY=
INSFORGE_API_BASE_URL=

# External A2A endpoints — specialists are disabled when these are absent
TENSORLAKE_A2A_ENDPOINT=
TENSORLAKE_A2A_AGENT_CARD_URL=
DEVIN_A2A_ENDPOINT=
DEVIN_A2A_AGENT_CARD_URL=
CONVEX_A2A_ENDPOINT=
CONVEX_A2A_AGENT_CARD_URL=

# Standalone Arbor A2A worker (a2a-worker/). Run it with
#   cd a2a-worker && npm install && PORT=4000 npm start
# then point Arbor at it. ARBOR_WORKER_BEARER only if the worker sets
# WORKER_BEARER_TOKEN.
ARBOR_WORKER_A2A_ENDPOINT=
ARBOR_WORKER_A2A_AGENT_CARD_URL=
ARBOR_WORKER_BEARER=

# Runtime A2A discovery directory — comma-separated base URLs of A2A agents.
# discover_specialist fetches each agent card and can mint tier:"a2a"
# specialists on demand. Empty = a2a discovery stage is skipped.
ARBOR_A2A_DIRECTORY=

# Anthropic (hive mind layers)
# Required by the planner/router/evaluator layers. Set this in Next/Vercel and
# on the Convex deployment, for example:
#   npx convex env set ANTHROPIC_API_KEY 'sk-ant-...'
ANTHROPIC_API_KEY=
# Optional: force deterministic local-hash embeddings for hive registry and
# scratchpad recall. Set in both Next/Vercel and Convex for consistent behavior.
HIVE_EMBEDDINGS_FORCE_LOCAL=false
# Optional: route all new tasks through the hive DAG planner by default. Must be
# set on the Convex deployment to affect tasks.post.
ARBOR_HIVE_DEFAULT=false
