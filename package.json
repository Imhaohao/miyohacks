{
  "name": "arbor",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.12.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "jira-agent:dev": "tsx services/jira-agent/server.ts",
    "build": "next build",
    "mcp:stdio": "tsx scripts/mcp-stdio.ts",
    "mcp:stdio:extensions": "tsx scripts/mcp-stdio.ts --surface extensions",
    "example:mcp-stdio": "tsx examples/mcp-stdio-client.ts",
    "demo:harness": "tsx scripts/demo-success-harness.ts",
    "start": "next start",
    "lint": "next lint",
    "convex:dev": "NODE_OPTIONS='--require ./scripts/node-styleText-polyfill.cjs' convex dev",
    "convex:once": "NODE_OPTIONS='--require ./scripts/node-styleText-polyfill.cjs' convex dev --once",
    "convex:env:sync-payment-secret": "node scripts/sync-convex-payment-secret.mjs",
    "grant:credits": "tsx scripts/grant-buyer-credits-once.ts",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.3",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.17.4",
    "hyperspell": "^1.0.0",
    "lucide-react": "^0.468.0",
    "next": "^15.5.18",
    "react": "^19.0.3",
    "react-dom": "^19.0.3",
    "recharts": "^2.15.0",
    "stripe": "^22.1.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
